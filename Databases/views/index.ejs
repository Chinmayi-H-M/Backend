<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Document</title>
    <link rel="stylesheet" href="/stylesheets/style.css">
    <script src="https://cdn.tailwindcss.com"></script>
</head>
<body>

    <div class="w-full h-full bg-black ">
        <div class="nav mb-10">
            <a class="text-white text-2xl font-bold mb-4" href="/read">Read users</a>
        </div>
        <h1 class="text-white text-2xl font-bold mb-4">Create user</h1>
        <hr>
        <form action="/create" method='POST'>
            <div class="flex flex-col gap-10">
            <input type="text" class="w-1/4 border-zinc-800 bg-transparent rounded-lg text-white p-2 m-2" placeholder='name' name="name">
            <input type="text" class="w-1/4 border-zinc-800 bg-transparent rounded-lg text-white p-2 m-2" placeholder='email' name="email">
            <input type="text" class="w-1/4 border-zinc-800 bg-transparent rounded-lg text-white p-2 m-2" placeholder='image' name="image">
            <input type="submit" name="" id="" class="w-1/3 mb-2 px-5 py-2 bg-blue-500 text-white rounded-lg" value="Create User">
            </div>
        </form>
    </div>
</body>
</html>