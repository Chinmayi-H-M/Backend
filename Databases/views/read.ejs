<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Document</title>
    <script src="https://cdn.tailwindcss.com"></script>
</head>
<body>
    <div class="nav mb-10">
            <a class="text-blue-400 text-2xl font-bold mb-4" href="/">Back to home</a>
        </div>
    <h1>The users</h1>
    <div class="w-full h-full bg-sinc-900 p-10 text-white">
        <h1 class="text-3xl tracking-tighter mb-3">All users</h1>
        <div class='users flex gap-4 flex-wrap'>
            <% if(users.length > 0) { %>
            <% users.forEach((user)=>{ %>
                <div class='user max-w-72 p-4 bg-zinc-800 rounded-lg mb-4'>
                    <div class='w-full h-52 rounded-lg bg-red-500 overflow-hidden'>
                        <img  class='w-full h-full object-cover' src="<%= user.image %>" alt="">
                    </div>
                    <h3 class='text-xl mt-3 tracking-tighter'><%= user.name %></h3>
                    <h5>Email: <%= user.email %></h5>
                    <div class="flex gap-3">
                        <a href="/edit/<%= user._id %>" class="text-blue-500 hover:text-blue-700">Edit</a>
                        <a href="/delete/<%= user._id %>" class="text-red-500 hover:text-red-700">Delete</a>
                    </div>
                </div>
            <% }) %>
            <% } else { %>
                <h1 class='text-2xl'>No users found</h1>
            <% } %>
        </div>
    </div>
</body>
</html>