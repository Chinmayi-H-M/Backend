<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Document</title>
    <script src="https://cdn.tailwindcss.com"></script>
</head>
<body>
    <div class="h-full w-full bg-zinc-900 text-white flex items-center justify-center p-10">
        <h1 class="text-3xl font-bold mb-6">Create User</h1>
        <form action="/create" method="post">
            <input type="text" class='bg-zinc-800 text-white placeholder:text-zinc-500 border border-zinc-500 focus:outline-none focus:ring-2 focus:ring-blue-500' placeholder="username" name="username">
            <input type="email" class='bg-zinc-800 text-white placeholder:text-zinc-500 border border-zinc-500 focus:outline-none focus:ring-2 focus:ring-blue-500' placeholder="email" name="email">
            <input type="password" class='bg-zinc-800 text-white placeholder:text-zinc-500 border border-zinc-500 focus:outline-none focus:ring-2 focus:ring-blue-500' placeholder="password" name="password">
            <input type="number" class='bg-zinc-800 text-white placeholder:text-zinc-500 border border-zinc-500 focus:outline-none focus:ring-2 focus:ring-blue-500' placeholder="age" name="age">
            <input type="submit" value="Create user" class='bg-blue-500 hover:bg-blue-600 text-white font-bold py-2 px-4 rounded'>
        </form>
    </div>
</body>
</html>